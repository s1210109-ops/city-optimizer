  <style>
    html,body { height:100%; margin:0; padding:0; box-sizing:border-box; }
    body {
      background: linear-gradient(135deg, #102244 0%, #44bfd8 100%);
      min-height: 100dvh;
      font-family: 'Microsoft JhengHei', 'Arial', sans-serif;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      user-select: none;
      overflow-x: hidden;
    }
    #main-stage {
      display: flex; flex-direction: column; align-items: center; margin: 2.5vw 0 0 0;
    }
    .goddess-card {
      background: rgba(0,255,255,0.13);
      border-radius: 1.8em;
      box-shadow: 0 6px 40px #0fd5ff76, 0 2px 30px #132339a8;
      padding: 20px 30px 32px 30px;
      min-width: 320px;
      min-height: 350px;
      display: flex; flex-direction: column; align-items: center;
      position: relative;
    }
    #three-canvas, .goddess-img {
      width:220px; height:240px; background:#232b42;
      border-radius: 42px;
      box-shadow: 0 8px 38px #0fffcf99, 0 2px 19px #2e334899;
      overflow: hidden;
      margin-bottom: 0;
      position:relative;
      z-index:1;
    }
    .chat-bubble {
      background: #fff; color: #188397;
      border-radius: 21px 21px 21px 8.5px;
      min-width: 68px; max-width: 200px;
      padding: 13px 17px;
      font-size: 1.13rem;
      position: absolute;
      left: 170px; top: -42px;
      box-shadow: 0 3px 18px #1beaff44;
      opacity: 0; transform: translateY(30px) scale(0.93);
      animation: bubbleIn 1.1s forwards;
      pointer-events: none;
      z-index: 12;
      border: 1.5px solid #B8F1FC;
      font-weight: bold;
    }
    @keyframes bubbleIn {
      to { opacity: 1; transform: translateY(0) scale(1);}
    }
    .goddess-name {
      font-size: 1.22rem; color: #15fbf1;
      font-weight: bold; margin: 10px 0 0 0; letter-spacing: 2px;
      text-shadow: 0 3px 14px #00f6ffa2;
      text-align:center
    }
    #slider-bar{display:flex;justify-content:center;align-items:center;gap:15px;margin:13px 0 7px 0;}
    .avatar-btn {
      width: 49px; height: 49px; border-radius: 50%;
      border: 2px solid #44f1ef;background: #f0fffd;
      box-shadow: 0 0 7px #00fff955;
      margin:0 2.5px;overflow:hidden;cursor:pointer;outline:none;
      display:flex;justify-content: center;align-items:center; padding:2px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .avatar-btn.selected {border:2.6px solid #ffe273; box-shadow:0 0 15px #ffe27399;}
    .avatar-btn img{width:100%; height:100%; object-fit:cover;}
    .slider-arrow {
      font-size: 2rem;
      color: #ffaa40;
      background: transparent; border: none; cursor: pointer; margin: 0 8px; user-select: none;
      transition: color 0.16s;
    }
    .slider-arrow:active { color: #39eaff; }
    #toolbox {margin-top:10px;display:flex;flex-direction:column;gap:10px;}
    .tool-row{display:flex;gap:10px;justify-content:center;}
    .tool-btn{
      background:linear-gradient(80deg,#18edff88 70%,#ffffff66);
      color:#075357;font-weight:bold;
      border:none;border-radius:7px;padding:10px 16px;
      box-shadow:0 0 7px #0ff9,inset 0 2px 9px #00fff939;transition:background 0.19s,color 0.16s;
      font-size:1rem;
      margin:0 2px;
      cursor:pointer;
    }
    .tool-btn:hover{background:#08efcc44;color:#154455;}
    .row-input{padding:7px;font-size:1rem;border-radius:5px;width:120px;}
    #status-bar {
      color:#fffdfc;text-align:center;letter-spacing:2px;
      font-size:1.12rem;margin-top:13px;font-weight:bold;text-shadow:0 2px 10px #13eaff63;
    }
    @media (max-width:600px){
      .goddess-card{min-width:98vw;padding:8vw 5vw;}
      #slider-bar{gap:6px;}
      #three-canvas{width:137vw;}
      #main-stage{margin-top:6vw;}
    }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/three@0.153.0/build/three.min.js"></script>
</head>
